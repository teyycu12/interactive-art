# Copy this file to .env (in project root OR backend/) and fill in your keys.
# .env is git-ignored.

# ── OpenRouter (current setup) ──────────────────────────────────────
# Key starts with sk-or-v1-...
# base_url is auto-detected from key prefix; you can override below.
OPENAI_API_KEY=sk-or-v1-...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1   # optional, auto-set when key starts with sk-or-

# ── Image-generation models ─────────────────────────────────────────
# IMPORTANT: only models that support OpenAI chat-completions
# `modalities=["image","text"]` work here — namely Google's Nano Banana
# family (Gemini *-flash-image / *-pro-image). FLUX models on OpenRouter
# use a different endpoint (/images/generations) and will return 404 here.
#
# body_sprite mode (AI generates upper+lower garments only; head/hands/feet
# are programmatic LEGO parts). Keep this Flash-tier for speed.
OUTFIT_GEN_MODEL=google/gemini-3.1-flash-image-preview

# full_character mode (AI generates the WHOLE LEGO figure: head + hair +
# face + body + legs + shoes — all in one image). Pro-tier is recommended
# because the model has to balance many parts; Flash-tier tends to drop
# details like shoes or paint mismatched colour patches.
FULL_CHARACTER_MODEL=google/gemini-3-pro-image-preview

# ── Generation mode ─────────────────────────────────────────────────
# Server default — the frontend mode-selector overrides this per request.
# body_sprite    → cheaper/faster, programmatic head + AI clothing
# full_character → slower/pricier, fully AI-generated minifigure
GENERATION_MODE=body_sprite

# ── Alternative: OpenAI official ────────────────────────────────────
# OPENAI_API_KEY=sk-proj-...
# OUTFIT_GEN_MODEL=gpt-image-1
# (leave OPENAI_BASE_URL unset)

# ── Gemini (existing — used by vlm_module.py for face/outfit detection) ──
GEMINI_API_KEY=
